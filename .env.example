# ================================
# AxonBridge — Environment Configuration
# ================================
# Copy this file to .env and fill in real values
# NEVER commit the .env file to version control

# ---------- Application ----------
APP_NAME=AxonBridge
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# ---------- Database (PostgreSQL) ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=axonbridge
POSTGRES_USER=axonbridge
POSTGRES_PASSWORD=changeme_secure_password_here
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# ---------- MinIO (Object Storage) ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=axonbridge_minio
MINIO_SECRET_KEY=changeme_minio_secret
MINIO_BUCKET_SCREENSHOTS=axonbridge-screenshots
MINIO_BUCKET_DOCUMENTS=axonbridge-documents
MINIO_USE_SSL=false

# ---------- JWT Authentication ----------
JWT_SECRET_KEY=changeme_jwt_secret_min_32_chars_long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Encryption (AES-256) ----------
ENCRYPTION_KEY=changeme_32_byte_encryption_key_here
ENCRYPTION_KEY_ROTATION_DAYS=90

# ---------- Security ----------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
RATE_LIMIT_PER_MINUTE=60
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
PASSWORD_MIN_LENGTH=12
MFA_ISSUER=AxonBridge

# ---------- Audit ----------
AUDIT_LOG_RETENTION_YEARS=7

# ---------- LLM Providers (Phase 3+) ----------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_AI_API_KEY=...

# ---------- Monitoring ----------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FORMAT=json
